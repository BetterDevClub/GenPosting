<MudPaper Class="pa-3 mb-3 rounded-lg d-flex align-center gap-3" Elevation="0"
         Style="@($"border-left: 4px solid {PlatformColor}; background-color: rgba(0,0,0,0.03);")">
    <MudAvatar Size="Size.Medium" Style="@($"background-color: {PlatformColor}; min-width: 40px;")">
        <MudIcon Icon="@Icon" Size="Size.Small" Style="color: white;" />
    </MudAvatar>
    <div class="flex-grow-1">
        <MudText Typo="Typo.body2" Style="font-weight: 600;">@PlatformName</MudText>
        @if (IsConnected)
        {
            <div class="d-flex align-center gap-1">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Style="color: #4CAF50; font-size: 0.9rem;" />
                <MudText Typo="Typo.caption" Style="color: #4CAF50;">Connected</MudText>
            </div>
        }
        else
        {
            <MudText Typo="Typo.caption" Style="opacity: 0.5;">Not connected</MudText>
        }
    </div>
    @if (!IsConnected)
    {
        <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" Href="@ConnectHref">
            Connect
        </MudButton>
    }
</MudPaper>

@code {
    [Parameter, EditorRequired] public string PlatformName { get; set; } = "";
    [Parameter, EditorRequired] public string Icon { get; set; } = "";
    [Parameter, EditorRequired] public string PlatformColor { get; set; } = "";
    [Parameter] public bool IsConnected { get; set; }
    [Parameter] public string ConnectHref { get; set; } = "/settings";
}
