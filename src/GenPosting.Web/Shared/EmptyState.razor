<MudPaper Class="@($"pa-8 d-flex flex-column align-center justify-center rounded-xl {Class}")"
         Elevation="0"
         Style="@($"background-color: {BackgroundColor}; min-height: {MinHeight};")">
    <MudIcon Icon="@Icon" Size="Size.Large" Color="@IconColor" Style="font-size: 3.5rem;" Class="mb-4" />
    <MudText Typo="Typo.h6" Align="Align.Center" GutterBottom="true">@Title</MudText>
    @if (!string.IsNullOrEmpty(Message))
    {
        <MudText Typo="Typo.body1" Align="Align.Center" Class="mb-6" Style="opacity: 0.7; max-width: 400px;">@Message</MudText>
    }
    @if (!string.IsNullOrEmpty(ActionLabel))
    {
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="@ActionHref" StartIcon="@ActionIcon">
            @ActionLabel
        </MudButton>
    }
    @ChildContent
</MudPaper>

@code {
    [Parameter] public string Icon { get; set; } = Icons.Material.Filled.Inbox;
    [Parameter] public Color IconColor { get; set; } = Color.Primary;
    [Parameter] public string Title { get; set; } = "Nothing here yet";
    [Parameter] public string? Message { get; set; }
    [Parameter] public string? ActionLabel { get; set; }
    [Parameter] public string? ActionHref { get; set; }
    [Parameter] public string ActionIcon { get; set; } = Icons.Material.Filled.Add;
    [Parameter] public string Class { get; set; } = "";
    [Parameter] public string MinHeight { get; set; } = "300px";
    [Parameter] public string BackgroundColor { get; set; } = "rgba(var(--mud-palette-primary-rgb), 0.03)";
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
