@inject NavigationManager Nav
@implements IDisposable

@code {
    [Parameter] public bool IsCollapsed { get; set; }

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
    }

    void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
        => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }

    bool IsActive(string href)
    {
        var uri = Nav.Uri;
        if (href == "")
            return uri == Nav.BaseUri || uri.TrimEnd('/') == Nav.BaseUri.TrimEnd('/');
        return uri.Contains($"/{href}", StringComparison.OrdinalIgnoreCase);
    }

    string ItemClass(string href) => $"gp-nav-item {(IsActive(href) ? "active" : "")}";
}

<div class="gp-nav-list">
    <a href="" class="@ItemClass("")">
        <span class="material-icons">dashboard</span>
        <span class="gp-nav-label">Dashboard</span>
    </a>
    <a href="calendar" class="@ItemClass("calendar")">
        <span class="material-icons">calendar_month</span>
        <span class="gp-nav-label">Calendar</span>
    </a>
    <a href="inbox" class="@ItemClass("inbox")">
        <span class="material-icons">inbox</span>
        <span class="gp-nav-label">Inbox</span>
    </a>
    <a href="analytics" class="@ItemClass("analytics")">
        <span class="material-icons">bar_chart</span>
        <span class="gp-nav-label">Analytics</span>
    </a>
</div>

