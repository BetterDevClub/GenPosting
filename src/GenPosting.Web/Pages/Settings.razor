@page "/settings"
@using GenPosting.Shared.DTOs
@using GenPosting.Web.Services
@inject HttpClient Http
@inject NavigationManager Nav
@inject ILinkedInStateService LinkedInState
@inject IInstagramStateService InstagramState
@inject IFacebookStateService FacebookState
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PageTitle>Settings - GenPosting</PageTitle>

<div class="d-flex align-center justify-space-between mb-6">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">Settings</MudText>
</div>

<!-- Connected Accounts -->
<MudText Typo="Typo.h6" Class="mb-4" Style="font-weight: 600;">Connected Accounts</MudText>
<MudGrid Class="mb-8">
    <!-- LinkedIn Card -->
    <MudItem xs="12" sm="6" md="4">
        <MudCard Style="border-top: 4px solid #0A66C2; height: 100%;" Elevation="2">
            <MudCardContent>
                <div class="d-flex align-center gap-3 mb-4">
                    <MudAvatar Style="background-color: #0A66C2;" Size="Size.Large">
                        <MudIcon Icon="@Icons.Custom.Brands.LinkedIn" Style="color: white;" />
                    </MudAvatar>
                    <div>
                        <MudText Typo="Typo.h6" Style="font-weight: 700;">LinkedIn</MudText>
                        @if (LinkedInState.IsAuthenticated)
                        {
                            <MudChip T="string" Size="Size.Small" Style="background-color: #4CAF50; color: white;" Icon="@Icons.Material.Filled.CheckCircle">Connected</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">Not connected</MudChip>
                        }
                    </div>
                </div>

                @if (LinkedInState.IsAuthenticated)
                {
                    @if (_profile != null)
                    {
                        <div class="d-flex align-center gap-2 mb-2">
                            <MudAvatar Size="Size.Small">
                                @if (!string.IsNullOrEmpty(_profile.PictureUrl))
                                {
                                    <MudImage Src="@_profile.PictureUrl" />
                                }
                                else
                                {
                                    @(_profile.Name.FirstOrDefault())
                                }
                            </MudAvatar>
                            <MudText Typo="Typo.body2"><b>@_profile.Name</b></MudText>
                        </div>
                    }
                    else
                    {
                        <MudSkeleton Width="140px" Height="24px" Class="mb-2" />
                    }
                }
                else
                {
                    <MudText Typo="Typo.body2" Style="opacity: 0.6;" Class="mb-2">Connect your LinkedIn account to schedule posts.</MudText>
                }
            </MudCardContent>
            <MudCardActions>
                @if (!LinkedInState.IsAuthenticated)
                {
                    <MudButton Variant="Variant.Filled" FullWidth="true" OnClick="ConnectLinkedIn"
                               Style="background-color: #0A66C2; color: white;" StartIcon="@Icons.Custom.Brands.LinkedIn">
                        Connect LinkedIn
                    </MudButton>
                }
                else
                {
                    <MudButton Variant="Variant.Outlined" FullWidth="true" Color="Color.Error" OnClick="DisconnectLinkedIn">
                        Disconnect
                    </MudButton>
                }
            </MudCardActions>
        </MudCard>
    </MudItem>

    <!-- Instagram Card -->
    <MudItem xs="12" sm="6" md="4">
        <MudCard Style="border-top: 4px solid #E1306C; height: 100%;" Elevation="2">
            <MudCardContent>
                <div class="d-flex align-center gap-3 mb-4">
                    <MudAvatar Style="background-color: #E1306C;" Size="Size.Large">
                        <MudIcon Icon="@Icons.Custom.Brands.Instagram" Style="color: white;" />
                    </MudAvatar>
                    <div>
                        <MudText Typo="Typo.h6" Style="font-weight: 700;">Instagram</MudText>
                        @if (InstagramState.IsAuthenticated)
                        {
                            <MudChip T="string" Size="Size.Small" Style="background-color: #4CAF50; color: white;" Icon="@Icons.Material.Filled.CheckCircle">Connected</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">Not connected</MudChip>
                        }
                    </div>
                </div>

                @if (InstagramState.IsAuthenticated)
                {
                    @if (_instagramProfile != null)
                    {
                        <div class="d-flex align-center gap-2 mb-2">
                            <MudAvatar Size="Size.Small">
                                @if (!string.IsNullOrEmpty(_instagramProfile.ProfilePictureUrl))
                                {
                                    <MudImage Src="@_instagramProfile.ProfilePictureUrl" />
                                }
                                else
                                {
                                    @(_instagramProfile.Username.FirstOrDefault())
                                }
                            </MudAvatar>
                            <MudText Typo="Typo.body2"><b>@@@_instagramProfile.Username</b></MudText>
                        </div>
                    }
                    else
                    {
                        <MudSkeleton Width="140px" Height="24px" Class="mb-2" />
                    }
                }
                else
                {
                    <MudText Typo="Typo.body2" Style="opacity: 0.6;" Class="mb-2">Connect your Instagram account to schedule posts.</MudText>
                }
            </MudCardContent>
            <MudCardActions>
                @if (!InstagramState.IsAuthenticated)
                {
                    <MudButton Variant="Variant.Filled" FullWidth="true" OnClick="ConnectInstagram"
                               Style="background-color: #E1306C; color: white;" StartIcon="@Icons.Custom.Brands.Instagram">
                        Connect Instagram
                    </MudButton>
                }
                else
                {
                    <MudButton Variant="Variant.Outlined" FullWidth="true" Color="Color.Error" OnClick="DisconnectInstagram">
                        Disconnect
                    </MudButton>
                }
            </MudCardActions>
        </MudCard>
    </MudItem>

    <!-- Facebook Card -->
    <MudItem xs="12" sm="6" md="4">
        <MudCard Style="border-top: 4px solid #1877F2; height: 100%;" Elevation="2">
            <MudCardContent>
                <div class="d-flex align-center gap-3 mb-4">
                    <MudAvatar Style="background-color: #1877F2;" Size="Size.Large">
                        <MudIcon Icon="@Icons.Custom.Brands.Facebook" Style="color: white;" />
                    </MudAvatar>
                    <div>
                        <MudText Typo="Typo.h6" Style="font-weight: 700;">Facebook</MudText>
                        @if (FacebookState.IsAuthenticated)
                        {
                            <MudChip T="string" Size="Size.Small" Style="background-color: #4CAF50; color: white;" Icon="@Icons.Material.Filled.CheckCircle">Connected</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">Not connected</MudChip>
                        }
                    </div>
                </div>

                @if (FacebookState.IsAuthenticated)
                {
                    @if (_facebookProfile != null)
                    {
                        <div class="d-flex align-center gap-2 mb-2">
                            <MudAvatar Size="Size.Small">
                                @if (!string.IsNullOrEmpty(_facebookProfile.ProfilePictureUrl))
                                {
                                    <MudImage Src="@_facebookProfile.ProfilePictureUrl" />
                                }
                                else
                                {
                                    @(_facebookProfile.Name.FirstOrDefault())
                                }
                            </MudAvatar>
                            <MudText Typo="Typo.body2"><b>@_facebookProfile.Name</b></MudText>
                        </div>
                    }
                    else
                    {
                        <MudSkeleton Width="140px" Height="24px" Class="mb-2" />
                    }
                }
                else
                {
                    <MudText Typo="Typo.body2" Style="opacity: 0.6;" Class="mb-2">Connect your Facebook account to schedule posts.</MudText>
                }
            </MudCardContent>
            <MudCardActions>
                @if (!FacebookState.IsAuthenticated)
                {
                    <MudButton Variant="Variant.Filled" FullWidth="true" OnClick="ConnectFacebook"
                               Style="background-color: #1877F2; color: white;" StartIcon="@Icons.Custom.Brands.Facebook">
                        Connect Facebook
                    </MudButton>
                }
                else
                {
                    <MudButton Variant="Variant.Outlined" FullWidth="true" Color="Color.Error" OnClick="DisconnectFacebook">
                        Disconnect
                    </MudButton>
                }
            </MudCardActions>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private LinkedInProfileDto? _profile;
    private InstagramUserDto? _instagramProfile;
    private FacebookUserDto? _facebookProfile;

    protected override async Task OnInitializedAsync()
    {
        if (LinkedInState.IsAuthenticated)
        {
            await LoadProfile();
        }
        if (InstagramState.IsAuthenticated)
        {
            await LoadInstagramProfile();
        }
        if (FacebookState.IsAuthenticated)
        {
            await LoadFacebookProfile();
        }
    }

    private async Task LoadProfile()
    {
        try 
        {
            var request = new HttpRequestMessage(HttpMethod.Get, "/api/linkedin/profile");
            request.Headers.Add("X-LinkedIn-Token", LinkedInState.AccessToken);
            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                _profile = await response.Content.ReadFromJsonAsync<LinkedInProfileDto>();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading profile: {ex.Message}");
        }
    }

    private async Task LoadInstagramProfile()
    {
        try 
        {
            var request = new HttpRequestMessage(HttpMethod.Get, $"/api/instagram/profile?userId={InstagramState.UserId}");
            request.Headers.Add("X-Instagram-Token", InstagramState.AccessToken);
            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                _instagramProfile = await response.Content.ReadFromJsonAsync<InstagramUserDto>();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading Instagram profile: {ex.Message}");
        }
    }

    private async Task LoadFacebookProfile()
    {
        try 
        {
            var request = new HttpRequestMessage(HttpMethod.Get, $"/api/facebook/profile?userId={FacebookState.UserId}");
            request.Headers.Add("X-Facebook-Token", FacebookState.AccessToken);
            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                _facebookProfile = await response.Content.ReadFromJsonAsync<FacebookUserDto>();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading Facebook profile: {ex.Message}");
        }
    }
        

    private async Task ConnectLinkedIn()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<LinkedInAuthUrlResponse>($"/api/linkedin/auth-url");
            
            if (response != null && !string.IsNullOrEmpty(response.AuthUrl))
            {
                if (string.IsNullOrEmpty(response.State))
                {
                    Snackbar.Add("Invalid authorization response: missing state parameter.", Severity.Error);
                    return;
                }
                await JS.InvokeVoidAsync("sessionStorage.setItem", "linkedin_oauth_state", response.State);
                Nav.NavigateTo(response.AuthUrl, forceLoad: true);
            }
            else
            {
                Snackbar.Add("Failed to get authorization URL", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private async Task DisconnectLinkedIn()
    {
        await LinkedInState.SetAccessTokenAsync(null);
        _profile = null;
        Snackbar.Add("Disconnected from LinkedIn", Severity.Success);
    }

    private async Task ConnectInstagram()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<InstagramAuthUrlResponse>($"/api/instagram/auth-url");
            
            if (response != null && !string.IsNullOrEmpty(response.AuthUrl))
            {
                if (string.IsNullOrEmpty(response.State))
                {
                    Snackbar.Add("Invalid authorization response: missing state parameter.", Severity.Error);
                    return;
                }
                await JS.InvokeVoidAsync("sessionStorage.setItem", "instagram_oauth_state", response.State);
                Nav.NavigateTo(response.AuthUrl, forceLoad: true);
            }
            else
            {
                Snackbar.Add("Failed to get authorization URL", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private async Task DisconnectInstagram()
    {
        await InstagramState.SetCredentialsAsync(null, null);
        _instagramProfile = null;
        Snackbar.Add("Disconnected from Instagram", Severity.Success);
    }

    private async Task ConnectFacebook()
    {
        try
        {
            var callbackUrl = Nav.ToAbsoluteUri("/facebook-callback").ToString();
            var encodedCallback = Uri.EscapeDataString(callbackUrl);
            var response = await Http.GetFromJsonAsync<FacebookAuthUrlResponse>($"/api/facebook/auth-url?redirectUri={encodedCallback}");
            
            if (response != null && !string.IsNullOrEmpty(response.AuthUrl))
            {
                Nav.NavigateTo(response.AuthUrl, forceLoad: true);
            }
            else
            {
                Snackbar.Add("Failed to get authorization URL", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private async Task DisconnectFacebook()
    {
        await FacebookState.SetCredentialsAsync(null, null);
        _facebookProfile = null;
        Snackbar.Add("Disconnected from Facebook", Severity.Success);
    }
}
