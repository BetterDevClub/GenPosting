@page "/create"
@using GenPosting.Shared.DTOs
@using GenPosting.Web.Services
@using GenPosting.Web.Components
@inject HttpClient Http
@inject NavigationManager Nav
@inject ILinkedInStateService LinkedInState
@inject IInstagramStateService InstagramState
@inject IFacebookStateService FacebookState
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime

<PageTitle>Create Post - GenPosting</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudGrid>
        <!-- LEFT COLUMN: Account Selection -->
        <MudItem xs="12" md="3">
            <MudPaper Class="pa-4 h-100" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-4">Select Accounts</MudText>
                
                @if (_loadingProfiles)
                {
                    <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                }
                else
                {
                    <!-- LinkedIn Account -->
                    <div class="d-flex align-center mb-3 pa-2 rounded @(_linkedInSelected ? "mud-theme-primary-hover" : "")" 
                         style="border: 1px solid #e0e0e0; cursor: pointer;" 
                         @onclick="@(() => ToggleLinkedIn(null))">
                        <MudCheckBox T="bool" Value="@_linkedInSelected" ValueChanged="@OnLinkedInChanged" Color="Color.Primary" Dense="true" StopClickPropagation="true" />
                        <div class="d-flex align-center gap-2 flex-grow-1">
                            @if (LinkedInState.IsAuthenticated)
                            {
                                @if (_linkedInProfile != null)
                                {
                                    <MudAvatar Size="Size.Medium">
                                        @if (!string.IsNullOrEmpty(_linkedInProfile.PictureUrl))
                                        {
                                            <MudImage Src="@_linkedInProfile.PictureUrl" />
                                        }
                                        else
                                        {
                                            @_linkedInProfile.Name.FirstOrDefault()
                                        }
                                    </MudAvatar>
                                    <div>
                                        <MudText Typo="Typo.body2" Style="font-weight: 600;">@_linkedInProfile.Name</MudText>
                                        <MudText Typo="Typo.caption">LinkedIn</MudText>
                                    </div>
                                }
                                else if (_loadingProfiles)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                    <MudText Typo="Typo.body2">LinkedIn (Loading...)</MudText>
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" />
                                    <div>
                                        <MudText Typo="Typo.body2" Color="Color.Warning">Session expired</MudText>
                                        <MudLink Href="/settings" Typo="Typo.caption">Reconnect LinkedIn →</MudLink>
                                    </div>
                                }
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Custom.Brands.LinkedIn" Color="Color.Default" />
                                <MudText Typo="Typo.body2">LinkedIn (Not Connected)</MudText>
                            }
                        </div>
                    </div>

                    <!-- Instagram Account -->
                    <div class="d-flex align-center pa-2 rounded @(_instagramSelected ? "mud-theme-secondary-hover" : "")" 
                         style="border: 1px solid #e0e0e0; cursor: pointer;"
                         @onclick="@(() => ToggleInstagram(null))">
                        <MudCheckBox T="bool" Value="@_instagramSelected" ValueChanged="@OnInstagramChanged" Color="Color.Secondary" Dense="true" StopClickPropagation="true"/>
                        <div class="d-flex align-center gap-2 flex-grow-1">
                            @if (InstagramState.IsAuthenticated)
                            {
                                @if (_instagramProfile != null)
                                {
                                    <MudAvatar Size="Size.Medium">
                                        @if (!string.IsNullOrEmpty(_instagramProfile.ProfilePictureUrl))
                                        {
                                            <MudImage Src="@_instagramProfile.ProfilePictureUrl" />
                                        }
                                        else
                                        {
                                            @(_instagramProfile.Username.FirstOrDefault())
                                        }
                                    </MudAvatar>
                                    <div>
                                        <MudText Typo="Typo.body2" Style="font-weight: 600;">@_instagramProfile.Username</MudText>
                                        <MudText Typo="Typo.caption">Instagram</MudText>
                                    </div>
                                }
                                else if (_loadingProfiles)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                    <MudText Typo="Typo.body2">Instagram (Loading...)</MudText>
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" />
                                    <div>
                                        <MudText Typo="Typo.body2" Color="Color.Warning">Session expired</MudText>
                                        <MudLink Href="/settings" Typo="Typo.caption">Reconnect Instagram →</MudLink>
                                    </div>
                                }
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Custom.Brands.Instagram" Color="Color.Default" />
                                <MudText Typo="Typo.body2">Instagram (Not Connected)</MudText>
                            }
                        </div>
                    </div>

                    <!-- Facebook Profile -->
                    <div class="d-flex align-center pa-2 rounded @(_facebookSelected ? "mud-theme-primary-hover" : "")" 
                         style="border: 1px solid #e0e0e0; cursor: pointer;"
                         @onclick="@(() => ToggleFacebook(null))">
                        <MudCheckBox T="bool" Value="@_facebookSelected" ValueChanged="@OnFacebookChanged" Color="Color.Primary" Dense="true" StopClickPropagation="true"/>
                        <div class="d-flex align-center gap-2 flex-grow-1">
                            @if (FacebookState.IsAuthenticated)
                            {
                                @if (_facebookProfile != null)
                                {
                                    <MudAvatar Size="Size.Medium" Style="background-color: #1877F2; color: white;">
                                        @if (!string.IsNullOrEmpty(_facebookProfile.ProfilePictureUrl))
                                        {
                                            <MudImage Src="@_facebookProfile.ProfilePictureUrl" />
                                        }
                                        else
                                        {
                                            @(_facebookProfile.Name.FirstOrDefault())
                                        }
                                    </MudAvatar>
                                    <div>
                                        <MudText Typo="Typo.body2" Style="font-weight: 600;">@_facebookProfile.Name</MudText>
                                        <MudText Typo="Typo.caption">Facebook Profile</MudText>
                                    </div>
                                }
                                else if (_loadingProfiles)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                    <MudText Typo="Typo.body2">Facebook (Loading...)</MudText>
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" />
                                    <div>
                                        <MudText Typo="Typo.body2" Color="Color.Warning">Session expired</MudText>
                                        <MudLink Href="/settings" Typo="Typo.caption">Reconnect Facebook →</MudLink>
                                    </div>
                                }
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Custom.Brands.Facebook" Color="Color.Default" />
                                <MudText Typo="Typo.body2">Facebook (Not Connected)</MudText>
                            }
                        </div>
                    </div>

                    @* Facebook Pages — each rendered as a separate account row *@
                    @if (_loadingFacebookPages)
                    {
                        <div class="d-flex align-center gap-2 pa-2 ml-2">
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                            <MudText Typo="Typo.caption">Loading pages...</MudText>
                        </div>
                    }
                    else
                    {
                        @foreach (var fbPage in _facebookPages)
                        {
                            var pid = fbPage.Id;
                            var isSelected = _facebookSelectedPageIds.Contains(pid);
                            <div class="d-flex align-center pa-2 rounded @(isSelected ? "mud-theme-primary-hover" : "")"
                                 style="border: 1px solid #e0e0e0; cursor: pointer; margin-top: 4px;"
                                 @onclick="@(() => ToggleFacebookPage(pid, !_facebookSelectedPageIds.Contains(pid)))">
                                <MudCheckBox T="bool"
                                             Value="@isSelected"
                                             ValueChanged="@(v => ToggleFacebookPage(pid, v))"
                                             Color="Color.Primary" Dense="true" StopClickPropagation="true" />
                                <div class="d-flex align-center gap-2 flex-grow-1">
                                    <MudAvatar Size="Size.Medium" Style="background-color: #1877F2; color: white;">
                                        @if (!string.IsNullOrEmpty(fbPage.ProfilePictureUrl))
                                        {
                                            <MudImage Src="@fbPage.ProfilePictureUrl" />
                                        }
                                        else
                                        {
                                            @(fbPage.Name.Length > 0 ? fbPage.Name[0] : 'F')
                                        }
                                    </MudAvatar>
                                    <div>
                                        <MudText Typo="Typo.body2" Style="font-weight: 600;">@fbPage.Name</MudText>
                                        <MudText Typo="Typo.caption">Facebook Page</MudText>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                }
            </MudPaper>
        </MudItem>

        <!-- MIDDLE COLUMN: Editor -->
        <MudItem xs="12" md="5">
            <MudPaper Class="pa-4 h-100" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-4">Compose</MudText>
                
                @if (_instagramSelected && !_linkedInSelected)
                {
                     <MudSelect T="InstagramPostType" Label="Instagram Post Type" @bind-Value="_instagramPostType" Variant="Variant.Outlined" Class="mb-4" Dense="true">
                        <MudSelectItem Value="@InstagramPostType.Post">Post (Feed)</MudSelectItem>
                        <MudSelectItem Value="@InstagramPostType.Reel">Reel</MudSelectItem>
                        <MudSelectItem Value="@InstagramPostType.Story">Story</MudSelectItem>
                    </MudSelect>
                }

                <div class="position-relative">
                    <MudTextField T="string" Label="What do you want to share?" Variant="Variant.Outlined" Lines="6" 
                                  @bind-Value="_postContent" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.EmojiEmotions" 
                                  Class="mb-1" HelperText="You can use hashtags and mentions"
                                  Immediate="true"
                                  UserAttributes="@(new Dictionary<string, object> { { "id", "post-caption-input" } })"
                                  OnKeyUp="OnCaptionKeyUp" />

                    <!-- Character counter per selected platform -->
                    <div class="d-flex gap-3 mb-3" style="font-size: 0.75rem; opacity: 0.7;">
                        @if (_linkedInSelected)
                        {
                            var liCount = _postContent?.Length ?? 0;
                            <span style="color: @(liCount > 3000 ? "#f44336" : liCount > 2700 ? "#FF9800" : "inherit")">
                                🔵 LinkedIn: @liCount / 3,000
                            </span>
                        }
                        @if (_instagramSelected)
                        {
                            var igCount = _postContent?.Length ?? 0;
                            <span style="color: @(igCount > 2200 ? "#f44336" : igCount > 1980 ? "#FF9800" : "inherit")">
                                🟣 Instagram: @igCount / 2,200
                            </span>
                        }
                        @if (_facebookSelected || _facebookSelectedPageIds.Count > 0)
                        {
                            var fbCount = _postContent?.Length ?? 0;
                            <span style="color: @(fbCount > 63206 ? "#f44336" : fbCount > 56885 ? "#FF9800" : "inherit")">
                                🔵 Facebook: @fbCount / 63,206
                            </span>
                        }
                    </div>

                    
                    <MudPopover Open="@_isMentionsOpen" AnchorOrigin="Origin.BottomLeft" TransformOrigin="Origin.TopLeft" RelativeWidth="DropdownWidth.Relative" Class="z-index-max" MaxHeight="300">
                        <MudList T="string">
                            <MudListSubheader>
                                Suggested Mentions (Friends & Business)
                            </MudListSubheader>
                            @if (_isSearchingMentions)
                            {
                                <MudListItem>
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                </MudListItem>
                            }
                            else if (!_mentionSuggestions.Any())
                            {
                                <MudListItem>
                                    <MudText Typo="Typo.caption">No accounts found matching "@_currentMentionQuery"</MudText>
                                </MudListItem>
                            }
                            else 
                            {
                                @foreach (var user in _mentionSuggestions)
                                {
                                    <MudListItem OnClick="@(() => SelectMention(user))">
                                        <div class="d-flex align-center gap-2">
                                            <MudAvatar Size="Size.Small">
                                                @if (!string.IsNullOrEmpty(user.ProfilePictureUrl))
                                                {
                                                    <MudImage Src="@user.ProfilePictureUrl" />
                                                }
                                                else
                                                {
                                                    @user.Username.FirstOrDefault()
                                                }
                                            </MudAvatar>
                                            <div>
                                                <MudText Typo="Typo.body2"><b>@user.Username</b></MudText>
                                                <MudText Typo="Typo.caption">@user.Name</MudText>
                                            </div>
                                        </div>
                                    </MudListItem>
                                }
                            }
                        </MudList>
                    </MudPopover>
                </div>

                <!-- Media Upload -->
                <div class="d-flex align-center gap-2 mb-4">
                     <MudFileUpload T="IReadOnlyList<IBrowserFile>" FilesChanged="UploadFiles" Accept=".png, .jpg, .jpeg, .mp4">
                        <ActivatorContent>
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.CloudUpload">
                                Add Media
                            </MudButton>
                        </ActivatorContent>
                    </MudFileUpload>
                    <MudText Typo="Typo.caption">Supported: JPG, PNG, MP4</MudText>
                </div>

                @if (_uploadedFiles.Any())
                {
                    <div class="d-flex gap-2 flex-wrap mb-4">
                        @foreach (var file in _uploadedFiles)
                        {
                            <MudChip T="string" OnClose="@(() => RemoveFile(file))" Color="Color.Primary" Variant="Variant.Text">
                                @(file.Name.Length > 20 ? file.Name.Substring(0, 17) + "..." : file.Name)
                            </MudChip>
                        }
                    </div>
                }

                <MudDivider Class="my-4" />

                <!-- Follow-up Comments -->
                <MudExpansionPanels Elevation="0" Class="mb-4">
                    <MudExpansionPanel Text="Follow-up Comments" Icon="@Icons.Material.Filled.Comment">
                         <div class="d-flex gap-2">
                            <MudTextField @bind-Value="_newComment" Label="Type a comment..." Variant="Variant.Outlined" Margin="Margin.Dense" />
                            <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary" OnClick="AddComment" />
                        </div>
                        
                        @if (_comments.Any())
                        {
                            <MudList T="string" Dense="true" Class="mt-2">
                                @foreach (var comment in _comments)
                                {
                                    <MudListItem>
                                        <div class="d-flex justify-space-between align-center">
                                            <MudText Typo="Typo.body2">@comment</MudText>
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => _comments.Remove(comment))" />
                                        </div>
                                    </MudListItem>
                                }
                            </MudList>
                        }
                    </MudExpansionPanel>
                </MudExpansionPanels>

                <!-- Scheduling -->
                <div class="d-flex align-center gap-2 mb-6">
                    <MudSwitch @bind-Value="_isScheduled" Color="Color.Primary" Label="Schedule for later" />
                </div>

                @if (_isScheduled)
                {
                    <div class="d-flex gap-4 mb-6">
                        <MudDatePicker Label="Date" @bind-Date="_scheduledDate" MinDate="DateTime.Today" />
                        <MudTimePicker Label="Time" @bind-Time="_scheduledTime" />
                    </div>
                }

                <!-- Action Buttons -->
                <div class="d-flex justify-end gap-2">
                     <MudButton Variant="Variant.Text" Color="Color.Error">Clear</MudButton>
                     <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SubmitPost" Disabled="@(_isPosting || (!_linkedInSelected && !_instagramSelected) || string.IsNullOrWhiteSpace(_postContent))">
                        @if (_isPosting)
                        {
                            <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                            <MudText Class="ms-2">Processing</MudText>
                        }
                        else
                        {
                            @(_isScheduled ? "Schedule Post" : "Post Now")
                        }
                    </MudButton>
                </div>

            </MudPaper>
        </MudItem>

        <!-- RIGHT COLUMN: Preview -->
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4 h-100" Elevation="2" Style="background-color: #f5f5f5;">
                <MudText Typo="Typo.h6" Class="mb-2">Preview</MudText>
                
                <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-2">
                    <MudTabPanel Text="LinkedIn" Icon="@Icons.Custom.Brands.LinkedIn" Disabled="@(!_linkedInSelected)">
                         <LinkedInPostPreview 
                            AuthorName="@(_linkedInProfile?.Name ?? "Your Name")"
                            AuthorAvatarUrl="@(_linkedInProfile?.PictureUrl)"
                            Content="@_postContent"
                            Images="@_previewImages"
                            VideoUrl="@_previewVideoUrl"
                         />
                    </MudTabPanel>
                    <MudTabPanel Text="Instagram" Icon="@Icons.Custom.Brands.Instagram" Disabled="@(!_instagramSelected)">
                        <InstagramPostPreview 
                            AuthorName="@(_instagramProfile?.Username ?? "username")"
                            AuthorAvatarUrl="@(_instagramProfile?.ProfilePictureUrl)" 
                            Content="@_postContent"
                            Images="@_previewImages"
                            VideoUrl="@_previewVideoUrl"
                            Comments="@_comments"
                        />
                    </MudTabPanel>
                    <MudTabPanel Text="Facebook" Icon="@Icons.Custom.Brands.Facebook" Disabled="@(!_facebookSelected && _facebookSelectedPageIds.Count == 0)">
                        <div class="pa-3" style="background: #f0f2f5; border-radius: 8px;">
                            <div class="d-flex align-center gap-2 mb-2">
                                <MudAvatar Size="Size.Small" Style="background-color: #1877F2; color: white; font-size: 0.75rem;">
                                    @(_facebookProfile?.Name.FirstOrDefault() ?? 'F')
                                </MudAvatar>
                                <div>
                                    <MudText Typo="Typo.body2" Style="font-weight: 600; line-height: 1.2;">@(_facebookProfile?.Name ?? "Your Name")</MudText>
                                    <MudText Typo="Typo.caption" Style="opacity: 0.6;">Just now · 🌐</MudText>
                                </div>
                            </div>
                            <MudText Typo="Typo.body2" Style="white-space: pre-wrap;">@_postContent</MudText>
                            @if (_previewImages.Any())
                            {
                                <MudImage Src="@_previewImages.First()" Alt="Preview" Class="mt-2" Style="max-width: 100%; border-radius: 4px;" />
                            }
                        </div>
                    </MudTabPanel>
                </MudTabs>
                
                @if (!_linkedInSelected && !_instagramSelected && !_facebookSelected && _facebookSelectedPageIds.Count == 0)
                {
                    <MudAlert Severity="Severity.Info" Class="mt-4">Select a platform to see the preview.</MudAlert>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private bool _loadingProfiles = true;
    private LinkedInProfileDto? _linkedInProfile;
    private InstagramUserDto? _instagramProfile;
    private FacebookUserDto? _facebookProfile;
    private List<FacebookPageDto> _facebookPages = new();
    private bool _loadingFacebookPages;
    private HashSet<string> _facebookSelectedPageIds = new();
    
    // Selection State
    private bool _linkedInSelected;
    private bool _instagramSelected;
    private bool _facebookSelected;
    private InstagramPostType _instagramPostType = InstagramPostType.Post;

    // Editor State
    private string _postContent = "";
    private List<IBrowserFile> _uploadedFiles = new();
    private List<string> _previewImages = new(); // Data URLs for preview
    private string? _previewVideoUrl;
    
    // Mention Support
    private bool _isMentionsOpen;
    private bool _isSearchingMentions;
    private List<InstagramUserSearchResultDto> _mentionSuggestions = new();
    private string _currentMentionQuery = "";
    private System.Timers.Timer _debounceTimer = new(500) { AutoReset = false };
    private List<FriendDto> _friends = new(); // Cached friends list

    // Follow-up Comments
    private string _newComment = "";
    private List<string> _comments = new();

    // Scheduling
    private bool _isScheduled;
    private DateTime? _scheduledDate = DateTime.Today;
    private TimeSpan? _scheduledTime = DateTime.Now.TimeOfDay.Add(TimeSpan.FromHours(1));

    private bool _isPosting;

    [SupplyParameterFromQuery(Name = "date")]
    public string? PresetDate { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _debounceTimer.Elapsed += async (s, e) => await InvokeAsync(SearchMentions);

        // Pre-fill date from query param (e.g. when clicking from Calendar)
        if (!string.IsNullOrEmpty(PresetDate) && DateTime.TryParse(PresetDate, out var parsedDate))
        {
            _scheduledDate = parsedDate;
            _isScheduled = true;
        }

        // Initialize all state services so localStorage tokens are loaded
        await Task.WhenAll(
            LinkedInState.InitializeAsync(),
            InstagramState.InitializeAsync(),
            FacebookState.InitializeAsync()
        );

        // Load Friends
        try
        {
            _friends = await Http.GetFromJsonAsync<List<FriendDto>>("/api/friends") ?? new();
        }
        catch {}

        await LoadProfiles();
    }

    private async Task LoadProfiles()
    {
        _loadingProfiles = true;
        try
        {
            if (LinkedInState.IsAuthenticated)
            {
                var req = new HttpRequestMessage(HttpMethod.Get, "/api/linkedin/profile");
                req.Headers.Add("X-LinkedIn-Token", LinkedInState.AccessToken);
                var res = await Http.SendAsync(req);
                if (res.IsSuccessStatusCode)
                {
                    _linkedInProfile = await res.Content.ReadFromJsonAsync<LinkedInProfileDto>();
                    _linkedInSelected = true; // Auto-select if connected
                }
            }

            if (InstagramState.IsAuthenticated)
            {
                var req = new HttpRequestMessage(HttpMethod.Get, $"/api/instagram/profile?userId={InstagramState.UserId}");
                req.Headers.Add("X-Instagram-Token", InstagramState.AccessToken);
                req.Headers.Add("X-Instagram-UserId", InstagramState.UserId);
                var res = await Http.SendAsync(req);
                if (res.IsSuccessStatusCode)
                {
                    _instagramProfile = await res.Content.ReadFromJsonAsync<InstagramUserDto>();
                    _instagramSelected = true; // Auto-select if connected
                }
            }

            if (FacebookState.IsAuthenticated)
            {
                var req = new HttpRequestMessage(HttpMethod.Get, $"/api/facebook/profile?userId={FacebookState.UserId}");
                req.Headers.Add("X-Facebook-Token", FacebookState.AccessToken);
                var res = await Http.SendAsync(req);
                if (res.IsSuccessStatusCode)
                {
                    _facebookProfile = await res.Content.ReadFromJsonAsync<FacebookUserDto>();
                    _facebookSelected = true; // Auto-select if connected
                }

                // Load pages in parallel so they appear as separate account rows
                await LoadFacebookPages();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load profiles: {ex.Message}", Severity.Warning);
        }
        finally
        {
            _loadingProfiles = false;
        }
    }

    private void OnLinkedInChanged(bool value) => ToggleLinkedIn(value);
    private void OnInstagramChanged(bool value) => ToggleInstagram(value);
    private void OnFacebookChanged(bool value) => ToggleFacebook(value);

    private void ToggleLinkedIn(bool? value = null)
    {
        if (LinkedInState.IsAuthenticated && _linkedInProfile != null)
        {
             _linkedInSelected = value ?? !_linkedInSelected;
        }
        else if (_linkedInProfile == null && LinkedInState.IsAuthenticated)
        {
            Snackbar.Add("LinkedIn session expired. Please reconnect in Settings.", Severity.Warning);
            _linkedInSelected = false;
        }
        else
        {
             Snackbar.Add("Connect LinkedIn first!", Severity.Warning);
             _linkedInSelected = false;
        }
    }

    private void ToggleInstagram(bool? value = null)
    {
        if (InstagramState.IsAuthenticated && _instagramProfile != null)
        {
             _instagramSelected = value ?? !_instagramSelected;
        }
        else if (_instagramProfile == null && InstagramState.IsAuthenticated)
        {
            Snackbar.Add("Instagram session expired. Please reconnect in Settings.", Severity.Warning);
            _instagramSelected = false;
        }
        else
        {
             Snackbar.Add("Connect Instagram first!", Severity.Warning);
             _instagramSelected = false;
        }
    }

    private void ToggleFacebook(bool? value = null)
    {
        if (FacebookState.IsAuthenticated && _facebookProfile != null)
            _facebookSelected = value ?? !_facebookSelected;
        else if (_facebookProfile == null && FacebookState.IsAuthenticated)
        {
            Snackbar.Add("Facebook session expired. Please reconnect in Settings.", Severity.Warning);
            _facebookSelected = false;
        }
        else
        {
            Snackbar.Add("Connect Facebook first!", Severity.Warning);
            _facebookSelected = false;
        }
    }

    private void ToggleFacebookPage(string pageId, bool selected)
    {
        if (selected) _facebookSelectedPageIds.Add(pageId);
        else _facebookSelectedPageIds.Remove(pageId);
    }

    private async Task LoadFacebookPages()
    {
        _loadingFacebookPages = true;
        try
        {
            var req = new HttpRequestMessage(HttpMethod.Get, $"/api/facebook/pages?userId={FacebookState.UserId}");
            req.Headers.Add("X-Facebook-Token", FacebookState.AccessToken);
            var res = await Http.SendAsync(req);
            if (res.IsSuccessStatusCode)
            {
                var response = await res.Content.ReadFromJsonAsync<FacebookPageListResponse>();
                _facebookPages = response?.Data ?? new();
            }
        }
        catch { }
        finally
        {
            _loadingFacebookPages = false;
            StateHasChanged();
        }
    }

    private async Task UploadFiles(IReadOnlyList<IBrowserFile> files)
    {
        foreach (var file in files)
        {
            if (_uploadedFiles.Any(f => f.Name == file.Name)) continue;
            
            _uploadedFiles.Add(file);

            // Generate Preview
            if (file.ContentType.StartsWith("image/"))
            {
                var buffer = new byte[file.Size];
                await file.OpenReadStream(20 * 1024 * 1024).ReadAsync(buffer);
                var base64 = Convert.ToBase64String(buffer);
                _previewImages.Add($"data:{file.ContentType};base64,{base64}");
            }
            // For video preview, we might need a different approach or just show a placeholder
        }
    }

    private void RemoveFile(IBrowserFile file)
    {
        _uploadedFiles.Remove(file);
        // Clear previews for simplicity, or manage index-based removal
        _previewImages.Clear(); 
        // Re-generate would be better but keeping it simple for now
    }

    private void AddComment()
    {
        if (!string.IsNullOrWhiteSpace(_newComment))
        {
            _comments.Add(_newComment);
            _newComment = "";
        }
    }

    private async Task SubmitPost()
    {
        _isPosting = true;
        try
        {
            var scheduledDateTime = (_isScheduled && _scheduledDate.HasValue && _scheduledTime.HasValue) 
                ? _scheduledDate.Value.Add(_scheduledTime.Value) 
                : (DateTime?)null;

            // 1. Post to LinkedIn
            if (_linkedInSelected)
            {
                await PostToLinkedIn(scheduledDateTime);
            }

            // 2. Post to Instagram
            if (_instagramSelected)
            {
                await PostToInstagram(scheduledDateTime);
            }

            // 3. Post to Facebook
            if (_facebookSelected || _facebookSelectedPageIds.Count > 0)
            {
                await PostToFacebook(scheduledDateTime);
            }
            
            Snackbar.Add("Operation completed!", Severity.Success);
            
            // Clear form
            _postContent = "";
            _uploadedFiles.Clear();
            _previewImages.Clear();
            _comments.Clear();
            _isScheduled = false;

        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isPosting = false;
        }
    }

    private async Task PostToLinkedIn(DateTime? scheduledAt)
    {
         // Logic similar to LinkedIn.razor 
         // Upload media first, then create post
         
         List<string> mediaUrns = new();
         string mediaType = "NONE";
         string? thumbnailUrl = _previewImages.FirstOrDefault(); // Simplified: using the base64 as thumbnail if needed, or null. LinkedIn usually needs a real URL.

         if (_uploadedFiles.Any())
         {
             var first = _uploadedFiles.First();
             mediaType = first.ContentType.StartsWith("video/") ? "VIDEO" : "IMAGE";
             
             foreach(var file in _uploadedFiles)
             {
                 var content = new MultipartFormDataContent();
                 var fileContent = new StreamContent(file.OpenReadStream(50 * 1024 * 1024));
                 fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
                 content.Add(fileContent, "file", file.Name);

                 var req = new HttpRequestMessage(HttpMethod.Post, "/api/linkedin/upload");
                 req.Headers.Add("X-LinkedIn-Token", LinkedInState.AccessToken);
                 req.Content = content;
                 
                 var res = await Http.SendAsync(req);
                 if (res.IsSuccessStatusCode)
                 {
                     var uploadDto = await res.Content.ReadFromJsonAsync<LinkedInUploadResponse>();
                     if(uploadDto != null) mediaUrns.Add(uploadDto.AssetUrn);
                 }
             }
         }

         var postReq = new CreateLinkedInPostRequest(_postContent, mediaUrns, mediaType, _comments, scheduledAt, thumbnailUrl);
         var reqMsg = new HttpRequestMessage(HttpMethod.Post, "/api/linkedin/post");
         reqMsg.Headers.Add("X-LinkedIn-Token", LinkedInState.AccessToken);
         reqMsg.Content = JsonContent.Create(postReq);
         
         var response = await Http.SendAsync(reqMsg);
         if (!response.IsSuccessStatusCode) throw new Exception("LinkedIn Post Failed");
    }

    private async Task PostToInstagram(DateTime? scheduledAt)
    {
        // Logic similar to Instagram.razor
        // Currently IG only supports 1 media file in this basic implementation unless we enhanced it
        // We'll take the first file
        
        var file = _uploadedFiles.FirstOrDefault();
        
        var content = new MultipartFormDataContent();
        if (file != null)
        {
            var fileContent = new StreamContent(file.OpenReadStream(50 * 1024 * 1024));
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
            content.Add(fileContent, "file", file.Name);
            
            // Determine PostType based on User Selection and Platform Context
            InstagramPostType typeToUse;
            if (_linkedInSelected)
            {
                // If multiple platforms (LinkedIn+IG) are selected, default strictly to Post
                typeToUse = InstagramPostType.Post;
            }
            else
            {
                // If only Instagram, respect the dropdown selection
                typeToUse = _instagramPostType;
            }
            content.Add(new StringContent(typeToUse.ToString()), "postType");
        }
        else
        {
            // IG requires media for now? Or maybe just text-only not supported? 
            // Standard IG requires media.
            if (string.IsNullOrWhiteSpace(_previewVideoUrl) && !_previewImages.Any())
            {
               throw new Exception("Instagram requires media (image/video).");
            }
        }

        content.Add(new StringContent(_postContent), "caption");
        
        // Handle Multiple Comments
        if (_comments.Any())
        {
            var commentsJson = System.Text.Json.JsonSerializer.Serialize(_comments);
            content.Add(new StringContent(commentsJson), "comments");
        }

        if (scheduledAt.HasValue)
        {
             content.Add(new StringContent(scheduledAt.Value.ToString("O")), "scheduledFor");
        }

        var req = new HttpRequestMessage(HttpMethod.Post, "/api/instagram/post");
        req.Headers.Add("X-Instagram-Token", InstagramState.AccessToken);
        req.Headers.Add("X-Instagram-UserId", InstagramState.UserId);
        req.Content = content;

        var res = await Http.SendAsync(req);
        if (!res.IsSuccessStatusCode) 
        {
            var err = await res.Content.ReadAsStringAsync();
            throw new Exception($"Instagram Failed: {err}");
        }
    }

    private async Task PostToFacebook(DateTime? scheduledAt)
    {
        var targets = new List<(string target, string? targetId)>();
        if (_facebookSelected)
            targets.Add(("Profile", null));
        foreach (var pageId in _facebookSelectedPageIds)
            targets.Add(("Page", pageId));

        foreach (var (target, targetId) in targets)
        {
            using var form = new MultipartFormDataContent();
            form.Add(new StringContent(_postContent), "content");
            form.Add(new StringContent("Text"), "postType");
            form.Add(new StringContent(target), "target");
            if (targetId != null)
                form.Add(new StringContent(targetId), "targetId");
            if (scheduledAt.HasValue)
                form.Add(new StringContent(scheduledAt.Value.ToString("o")), "scheduledFor");

            if (_uploadedFiles.Count > 0)
            {
                var file = _uploadedFiles[0];
                var stream = file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
                form.Add(new StreamContent(stream), "file", file.Name);
            }

            var req = new HttpRequestMessage(HttpMethod.Post, "/api/facebook/post") { Content = form };
            req.Headers.Add("X-Facebook-Token", FacebookState.AccessToken);
            req.Headers.Add("X-Facebook-UserId", FacebookState.UserId);

            var res = await Http.SendAsync(req);
            if (!res.IsSuccessStatusCode)
            {
                var err = await res.Content.ReadAsStringAsync();
                throw new Exception($"Facebook Failed ({target}): {err}");
            }
        }
    }

    private async Task OnCaptionKeyUp(KeyboardEventArgs args)
    {
        if (!_instagramSelected && !_linkedInSelected) return;

        try
        {
            // Note: Requires unsafe-eval in CSP or moving to a function in wwwroot/index.html
            int caretPos = await JSRuntime.InvokeAsync<int>("eval", "document.getElementById('post-caption-input').selectionStart");
            
            if (string.IsNullOrEmpty(_postContent) || caretPos <= 0) 
            {
                _isMentionsOpen = false;
                return;
            }

            string textBeforeCaret = _postContent.Substring(0, caretPos);
            int atIndex = textBeforeCaret.LastIndexOf('@');

            if (atIndex == -1) 
            {
                _isMentionsOpen = false;
                return;
            }

            string token = textBeforeCaret.Substring(atIndex + 1);
            // Mentions shouldn't have spaces or newlines
            if (token.Contains(" ") || token.Contains("\n"))
            {
                 _isMentionsOpen = false;
                 return;
            }

            _currentMentionQuery = token;
            // Only search if length > 1 to avoid spamming for every single char immediately
            if (_currentMentionQuery.Length > 1) 
            {
                _isMentionsOpen = true; 
                _isSearchingMentions = true;
                _debounceTimer.Stop();
                _debounceTimer.Start();
            }
            else
            {
                _isMentionsOpen = false;
            }
        }
        catch (Exception)
        {
            // Ignore JS interoperability errors
        }
    }

    private async Task SearchMentions()
    {
        if (string.IsNullOrWhiteSpace(_currentMentionQuery)) return;

        try 
        {
             var results = new List<InstagramUserSearchResultDto>();

             // 1. Search Local Friends First
             // A. LinkedIn Friends (if LinkedIn selected)
             if (_linkedInSelected)
             {
                 var liFriends = _friends
                    .Where(f => !string.IsNullOrEmpty(f.LinkedInUrn))
                    .Where(f => f.Name.Contains(_currentMentionQuery, StringComparison.OrdinalIgnoreCase))
                    .Select(f => new InstagramUserSearchResultDto(f.Name, "LinkedIn Contact", "", f.LinkedInUrn!));
                 
                 results.AddRange(liFriends);
             }

             // B. Instagram Friends (if Instagram selected)
             if (_instagramSelected)
             {
                 var igFriends = _friends
                     .Where(f => !string.IsNullOrEmpty(f.InstagramUsername))
                     .Where(f => f.Name.Contains(_currentMentionQuery, StringComparison.OrdinalIgnoreCase) || 
                                 f.InstagramUsername!.Contains(_currentMentionQuery, StringComparison.OrdinalIgnoreCase))
                     .Select(f => new InstagramUserSearchResultDto(f.InstagramUsername!, f.Name, "", f.Id.ToString()));
                 
                 // Deduplicate if already added (unlikely as format differs, but good practice)
                 foreach (var f in igFriends)
                 {
                     if (!results.Any(r => r.Id == f.Id && r.Username == f.Username))
                        results.Add(f);
                 }
             }

             // 2. Search Instagram Business API
             if (_instagramSelected && InstagramState.IsAuthenticated)
             {
                 var request = new HttpRequestMessage(HttpMethod.Get, $"/api/instagram/users/search?query={_currentMentionQuery}");
                 request.Headers.Add("X-Instagram-Token", InstagramState.AccessToken);
                 request.Headers.Add("X-Instagram-UserId", InstagramState.UserId);

                 var response = await Http.SendAsync(request);
                 if (response.IsSuccessStatusCode)
                 {
                     var apiResults = await response.Content.ReadFromJsonAsync<List<InstagramUserSearchResultDto>>();
                     if (apiResults != null)
                     {
                         // Avoid duplicates if API returns same user as local friend (unlikely but possible if IDs match)
                         foreach(var r in apiResults)
                         {
                             if (!results.Any(existing => existing.Username.Equals(r.Username, StringComparison.OrdinalIgnoreCase)))
                             {
                                 results.Add(r);
                             }
                         }
                     }
                 }
             }

             _mentionSuggestions = results;
        }
        catch 
        {
             // Fallback to empty
             _mentionSuggestions = new();
        }
        finally
        {
            _isSearchingMentions = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void SelectMention(InstagramUserSearchResultDto user)
    {
         // Find the last occurrence of the query relative to where we think the caret is/was
         int atIndex = _postContent.LastIndexOf("@" + _currentMentionQuery);
         if (atIndex != -1)
         {
             var before = _postContent.Substring(0, atIndex);
             var afterStart = atIndex + 1 + _currentMentionQuery.Length;
             var after = afterStart < _postContent.Length ? _postContent.Substring(afterStart) : "";
             
             // Determine Mention Format
             string mentionText;
             // Check if it's a LinkedIn URN (starts with urn:li:)
             if (user.Id.StartsWith("urn:li:"))
             {
                 // LinkedIn Format: @[Name](URN)
                 // Note: user.Username holds the Name for LinkedIn contacts based on our search logic
                 mentionText = $"@[{user.Username}]({user.Id})";
             }
             else 
             {
                 // Default/Instagram Format: @username
                 mentionText = $"@{user.Username}";
             }
             
             _postContent = $"{before}{mentionText} {after}";
             _isMentionsOpen = false;
         }
    }
