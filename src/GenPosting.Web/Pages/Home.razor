@page "/"
@using GenPosting.Shared.DTOs
@using GenPosting.Shared.Enums
@using GenPosting.Web.Services
@inject HttpClient Http
@inject ILinkedInStateService LinkedInState
@inject IInstagramStateService InstagramState
@inject IFacebookStateService FacebookState

<PageTitle>Dashboard - GenPosting</PageTitle>

<div class="gp-page">

@if (!_anyConnected && !_loading)
{
    <!-- Welcome / onboarding state -->
    <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 60vh; text-align: center;">
        <div style="width: 80px; height: 80px; border-radius: 24px; background: var(--gp-gradient); display: flex; align-items: center; justify-content: center; margin-bottom: 24px; box-shadow: 0 8px 32px rgba(124,58,237,0.35);">
            <MudIcon Icon="@Icons.Material.Filled.Hub" Style="font-size: 2.5rem; color: white;" />
        </div>
        <MudText Typo="Typo.h4" GutterBottom="true">Welcome to GenPosting!</MudText>
        <MudText Typo="Typo.body1" Class="mb-8" Style="opacity: 0.65; max-width: 400px;">
            Connect your social media accounts to start scheduling and publishing posts across all platforms.
        </MudText>
        <MudStack Row="true" Spacing="3" Justify="Justify.Center" Wrap="Wrap.Wrap">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Href="/settings"
                       StartIcon="@Icons.Custom.Brands.LinkedIn">Connect LinkedIn</MudButton>
            <MudButton Variant="Variant.Filled" Size="Size.Large" Href="/settings"
                       StartIcon="@Icons.Custom.Brands.Instagram"
                       Style="background: var(--gp-gradient-instagram); color: white;">Connect Instagram</MudButton>
            <MudButton Variant="Variant.Filled" Size="Size.Large" Href="/settings"
                       StartIcon="@Icons.Custom.Brands.Facebook"
                       Style="background: var(--gp-gradient-facebook); color: white;">Connect Facebook</MudButton>
        </MudStack>
    </div>
}
else
{
    <!-- Greeting -->
    <div Class="mb-6" style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px;">
        <div>
            <MudText Typo="Typo.h5" Style="margin-bottom: 2px;">@_greeting 👋</MudText>
            <MudText Typo="Typo.body2" Style="opacity: 0.55;">Here's your social media overview</MudText>
        </div>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/create"
                   StartIcon="@Icons.Material.Filled.EditNote" Size="Size.Medium">
            New Post
        </MudButton>
    </div>

    <!-- Stats Row -->
    <MudGrid Class="mb-6">
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-5 gp-card-hover gp-stat-scheduled" Elevation="0">
                <MudText Typo="Typo.overline" Style="opacity: 0.6; font-weight: 600;">Scheduled</MudText>
                <MudText Typo="Typo.h3" Style="font-weight: 800; margin: 4px 0 0;">@_scheduledCount</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-5 gp-card-hover gp-stat-published" Elevation="0">
                <MudText Typo="Typo.overline" Style="opacity: 0.6; font-weight: 600;">Published</MudText>
                <MudText Typo="Typo.h3" Style="font-weight: 800; margin: 4px 0 0;">@_publishedCount</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-5 gp-card-hover gp-stat-failed" Elevation="0">
                <MudText Typo="Typo.overline" Style="opacity: 0.6; font-weight: 600;">Failed</MudText>
                <MudText Typo="Typo.h3" Style="font-weight: 800; margin: 4px 0 0;">@_failedCount</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-5 gp-card-hover gp-stat-connected" Elevation="0">
                <MudText Typo="Typo.overline" Style="opacity: 0.6; font-weight: 600;">Connected</MudText>
                <MudText Typo="Typo.h3" Style="font-weight: 800; margin: 4px 0 0;">@_connectedCount</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudGrid>
        <!-- Upcoming Posts -->
        <MudItem xs="12" md="7">
            <MudPaper Class="pa-5" Elevation="0" Style="height: 100%;">
                <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px;">
                    <MudText Typo="Typo.h6">Upcoming Posts</MudText>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/calendar"
                               EndIcon="@Icons.Material.Filled.ArrowForward" Size="Size.Small">
                        View Calendar
                    </MudButton>
                </div>

                @if (_loading)
                {
                    @for (int i = 0; i < 4; i++)
                    {
                        <MudSkeleton Height="64px" Class="mb-2" Style="border-radius: 10px;" />
                    }
                }
                else if (!_upcomingPosts.Any())
                {
                    <EmptyState Icon="@Icons.Material.Filled.CalendarMonth"
                                Title="No posts scheduled"
                                Message="Create your first post to see it here."
                                ActionLabel="Create Post"
                                ActionHref="/create"
                                MinHeight="180px" />
                }
                else
                {
                    @foreach (var post in _upcomingPosts)
                    {
                        <div class="gp-post-row" @onclick="@(() => NavigateToCalendar())"
                             style="@($"border-left: 3px solid {GetPlatformColor(post.Platform)};")">
                            <MudAvatar Size="Size.Small"
                                       Style="@($"background: {GetPlatformColor(post.Platform)}; min-width: 32px; width: 32px; height: 32px;")">
                                <MudIcon Icon="@GetPlatformIcon(post.Platform)" Size="Size.Small" Style="color: white; font-size: 0.875rem;" />
                            </MudAvatar>
                            <div style="flex: 1; min-width: 0;">
                                <div style="font-size: 0.875rem; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                    @(string.IsNullOrEmpty(post.Content) ? "[Media post]" : post.Content)
                                </div>
                                <div style="font-size: 0.75rem; opacity: 0.55; margin-top: 2px;">
                                    @GetPlatformName(post.Platform) · @FormatScheduledTime(post.ScheduledTime)
                                </div>
                            </div>
                            <span class="gp-status-pill" style="@GetStatusStyle(post.Status)">@post.Status</span>
                        </div>
                    }
                }
            </MudPaper>
        </MudItem>

        <!-- Platform Health -->
        <MudItem xs="12" md="5">
            <MudPaper Class="pa-5" Elevation="0" Style="height: 100%;">
                <MudText Typo="Typo.h6" Class="mb-4">Connected Accounts</MudText>

                <PlatformHealthCard
                    PlatformName="LinkedIn"
                    Icon="@Icons.Custom.Brands.LinkedIn"
                    PlatformColor="#0A66C2"
                    IsConnected="@LinkedInState.IsAuthenticated"
                    ConnectHref="/settings" />

                <PlatformHealthCard
                    PlatformName="Instagram"
                    Icon="@Icons.Custom.Brands.Instagram"
                    PlatformColor="#E1306C"
                    IsConnected="@InstagramState.IsAuthenticated"
                    ConnectHref="/settings" />

                <PlatformHealthCard
                    PlatformName="Facebook"
                    Icon="@Icons.Custom.Brands.Facebook"
                    PlatformColor="#1877F2"
                    IsConnected="@FacebookState.IsAuthenticated"
                    ConnectHref="/settings" />

                <MudButton Variant="Variant.Outlined" FullWidth="true" Color="Color.Primary" Href="/settings"
                           StartIcon="@Icons.Material.Filled.ManageAccounts" Class="mt-3">
                    Manage Accounts
                </MudButton>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

</div>

@code {
    private List<ScheduledPostDto> _upcomingPosts = new();
    private bool _loading = true;
    private int _scheduledCount, _publishedCount, _failedCount, _connectedCount;
    private bool _anyConnected;
    private string _greeting = "Good day";

    [Inject] private NavigationManager Nav { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        var hour = DateTime.Now.Hour;
        _greeting = hour < 12 ? "Good morning" : hour < 17 ? "Good afternoon" : "Good evening";

        _anyConnected = LinkedInState.IsAuthenticated || InstagramState.IsAuthenticated || FacebookState.IsAuthenticated;
        _connectedCount = (LinkedInState.IsAuthenticated ? 1 : 0) + (InstagramState.IsAuthenticated ? 1 : 0) + (FacebookState.IsAuthenticated ? 1 : 0);

        if (_anyConnected)
            await LoadData();
        else
            _loading = false;
    }

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            var all = await Http.GetFromJsonAsync<List<ScheduledPostDto>>("/api/linkedin/scheduled") ?? new();
            var now = DateTimeOffset.Now;
            _upcomingPosts = all.Where(p => p.ScheduledTime > now && p.Status == "Pending")
                                .OrderBy(p => p.ScheduledTime)
                                .Take(6)
                                .ToList();
            _scheduledCount = all.Count(p => p.Status == "Pending");
            _publishedCount = all.Count(p => p.Status == "Published");
            _failedCount = all.Count(p => p.Status == "Failed");
        }
        catch { }
        finally
        {
            _loading = false;
        }
    }

    private void NavigateToCalendar() => Nav.NavigateTo("/calendar");

    private static string GetPlatformColor(SocialPlatform p) => p switch
    {
        SocialPlatform.LinkedIn => "#0A66C2",
        SocialPlatform.Instagram => "#E1306C",
        SocialPlatform.Facebook => "#1877F2",
        _ => "#757575"
    };

    private static string GetPlatformIcon(SocialPlatform p) => p switch
    {
        SocialPlatform.LinkedIn => Icons.Custom.Brands.LinkedIn,
        SocialPlatform.Instagram => Icons.Custom.Brands.Instagram,
        SocialPlatform.Facebook => Icons.Custom.Brands.Facebook,
        _ => Icons.Material.Filled.Public
    };

    private static string GetPlatformName(SocialPlatform p) => p.ToString();

    private static string FormatScheduledTime(DateTimeOffset t)
    {
        var local = t.ToLocalTime();
        if (local.Date == DateTime.Today) return $"Today {local:HH:mm}";
        if (local.Date == DateTime.Today.AddDays(1)) return $"Tomorrow {local:HH:mm}";
        return local.ToString("d MMM, HH:mm");
    }

    private static string GetStatusStyle(string status) => status switch
    {
        "Published" => "background: #10B981; color: white; padding: 2px 10px; border-radius: 50px; font-size: 0.75rem; font-weight: 600; white-space: nowrap;",
        "Failed"    => "background: #EF4444; color: white; padding: 2px 10px; border-radius: 50px; font-size: 0.75rem; font-weight: 600; white-space: nowrap;",
        _           => "background: rgba(0,0,0,0.08); color: rgba(0,0,0,0.6); padding: 2px 10px; border-radius: 50px; font-size: 0.75rem; font-weight: 600; white-space: nowrap;"
    };
}

