@page "/facebook"
@using GenPosting.Shared.DTOs
@using GenPosting.Web.Services
@inject HttpClient Http
@inject NavigationManager Nav
@inject IFacebookStateService FacebookState
@inject ISnackbar Snackbar
@inject IDialogService DialogService

@if (!FacebookState.IsAuthenticated)
{
    <MudPaper Class="pa-8 d-flex flex-column align-center justify-center" Elevation="2">
        <MudIcon Icon="@Icons.Custom.Brands.Facebook" Size="Size.Large" Color="Color.Primary" Class="mb-4" Style="font-size: 4rem;" />
        <MudText Typo="Typo.h5" Class="mb-4">Facebook Not Connected</MudText>
        <MudText Typo="Typo.body1" Class="mb-6">Please connect your Facebook account in Settings to create content.</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Href="/settings" StartIcon="@Icons.Material.Filled.Settings">
            Go to Settings
        </MudButton>
    </MudPaper>
}
else
{
    <MudPaper Class="pa-4 mb-4 d-flex align-center gap-4" Elevation="1">
        @if (_isLoadingProfile)
        {
             <MudSkeleton SkeletonType="SkeletonType.Circle" Width="64px" Height="64px" />
             <div>
                 <MudSkeleton Width="150px" Height="30px" Class="mb-1"/>
                 <MudSkeleton Width="100px" Height="20px" />
             </div>
        }
        else if (_profile != null)
        {
            <MudAvatar Size="Size.Large">
                @if (!string.IsNullOrEmpty(_profile.ProfilePictureUrl))
                {
                    <MudImage Src="@_profile.ProfilePictureUrl" />
                }
                else
                {
                    @(_profile.Name.FirstOrDefault())
                }
            </MudAvatar>
            <div>
                <MudText Typo="Typo.h6">@_profile.Name</MudText>
                <MudText Typo="Typo.caption">Facebook Account</MudText>
            </div>
        }
        <MudSpacer />
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="LoadMyPosts" StartIcon="@Icons.Material.Filled.Person">
            My Posts
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="LoadPages" StartIcon="@Icons.Material.Filled.Refresh">
            Reload Pages
        </MudButton>
    </MudPaper>

    @if (_pages != null && _pages.Any())
    {
        <MudPaper Class="pa-4 mb-4" Elevation="1">
            <MudText Typo="Typo.h6" Class="mb-4">Your Facebook Pages</MudText>
            <MudGrid>
                @foreach (var pageItem in _pages)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudCard>
                            <MudCardHeader>
                                <CardHeaderAvatar>
                                    <MudAvatar>
                                        @if (!string.IsNullOrEmpty(pageItem.ProfilePictureUrl))
                                        {
                                            <MudImage Src="@pageItem.ProfilePictureUrl" />
                                        }
                                        else
                                        {
                                            @pageItem.Name.FirstOrDefault()
                                        }
                                    </MudAvatar>
                                </CardHeaderAvatar>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.body1">@pageItem.Name</MudText>
                                    <MudText Typo="Typo.body2">@pageItem.Category</MudText>
                                </CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudText Typo="Typo.body2">Fans: @pageItem.FanCount.ToString("N0")</MudText>
                                <MudText Typo="Typo.body2">Followers: @pageItem.FollowersCount.ToString("N0")</MudText>
                            </MudCardContent>
                            <MudCardActions>
                                <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => ViewPagePosts(pageItem.Id, true))">View Posts</MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        </MudPaper>
    }

    @if (_posts != null && _posts.Any())
    {
        <MudPaper Class="pa-4" Elevation="1">
            <div class="d-flex align-center justify-space-between mb-4">
                <MudText Typo="Typo.h6">@_postsTitle</MudText>
                @if (_isLoadingPosts)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                }
            </div>
            <MudGrid>
                @foreach (var post in _posts)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudCard>
                            @if (!string.IsNullOrEmpty(post.FullPicture))
                            {
                                <MudCardMedia Image="@post.FullPicture" Height="200" />
                            }
                            <MudCardContent>
                                <MudText Typo="Typo.body2" Class="mb-2">@(post.Message ?? post.Story ?? "No content")</MudText>
                                <MudChip T="string" Size="Size.Small" Color="Color.Info">@post.Type</MudChip>
                                <MudText Typo="Typo.caption" Class="mt-2">
                                    @DateTime.Parse(post.CreatedTime).ToString("MMM dd, yyyy")
                                </MudText>
                            </MudCardContent>
                            <MudCardActions>
                                <MudButton Variant="Variant.Text" Color="Color.Primary" Href="@post.Permalink" Target="_blank" Size="Size.Small" StartIcon="@Icons.Material.Filled.OpenInNew">
                                    View on Facebook
                                </MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        </MudPaper>
    }
}

@code {
    private FacebookUserDto? _profile;
    private List<FacebookPageDto>? _pages;
    private List<FacebookPostDto>? _posts;
    private bool _isLoadingProfile = true;
    private bool _isLoadingPosts = false;
    private string _postsTitle = "Recent Posts";

    protected override async Task OnInitializedAsync()
    {
        await FacebookState.InitializeAsync();
        
        if (FacebookState.IsAuthenticated)
        {
            await LoadProfile();
            await LoadPages();
            await LoadMyPosts(); // Load personal posts by default
        }
    }

    private async Task LoadProfile()
    {
        _isLoadingProfile = true;
        try
        {
            var request = new HttpRequestMessage(HttpMethod.Get, $"/api/facebook/profile?userId={FacebookState.UserId}");
            request.Headers.Add("X-Facebook-Token", FacebookState.AccessToken);
            
            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                _profile = await response.Content.ReadFromJsonAsync<FacebookUserDto>();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load profile: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoadingProfile = false;
        }
    }

    private async Task LoadPages()
    {
        try
        {
            var request = new HttpRequestMessage(HttpMethod.Get, $"/api/facebook/pages?userId={FacebookState.UserId}");
            request.Headers.Add("X-Facebook-Token", FacebookState.AccessToken);
            
            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<FacebookPageListResponse>();
                _pages = result?.Data;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load pages: {ex.Message}", Severity.Error);
        }
    }

    private async Task LoadMyPosts()
    {
        _isLoadingPosts = true;
        _postsTitle = "My Posts";
        StateHasChanged();
        
        try
        {
            var request = new HttpRequestMessage(HttpMethod.Get, $"/api/facebook/posts?targetId={FacebookState.UserId}&isPage=false");
            request.Headers.Add("X-Facebook-Token", FacebookState.AccessToken);
            
            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<FacebookPostListResponse>();
                _posts = result?.Data;
                Snackbar.Add($"Loaded {_posts?.Count ?? 0} posts", Severity.Success);
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Failed to load posts: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load posts: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoadingPosts = false;
            StateHasChanged();
        }
    }

    private async Task ViewPagePosts(string pageId, bool isPage)
    {
        _isLoadingPosts = true;
        _postsTitle = isPage ? "Page Posts" : "Posts";
        StateHasChanged();
        
        try
        {
            var request = new HttpRequestMessage(HttpMethod.Get, $"/api/facebook/posts?targetId={pageId}&isPage={isPage}");
            request.Headers.Add("X-Facebook-Token", FacebookState.AccessToken);
            
            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<FacebookPostListResponse>();
                _posts = result?.Data;
                
                var pageName = _pages?.FirstOrDefault(p => p.Id == pageId)?.Name ?? "Page";
                _postsTitle = $"{pageName} Posts";
                Snackbar.Add($"Loaded {_posts?.Count ?? 0} posts", Severity.Success);
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Failed to load posts: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load posts: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoadingPosts = false;
            StateHasChanged();
        }
    }
}
